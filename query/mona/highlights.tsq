
(digits) @l.number

(integer ["-" "0x" "0b" "0o" "0z"] @l.number.affix)
(integer (literal_suffix) @l.number.affix)

(parenthetical ["(" ")"] @o.group)

(function ["{" "}"] @o.declare.function)
