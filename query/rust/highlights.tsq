(call_expression function: (name) @_ (#semantic? @_ EnumMember) arguments: (arguments ["(" "," ")"] @o.call.value.variant))
(call_expression function: (scoped_name name: (name) @_ (#semantic? @_ EnumMember)) arguments: (arguments ["(" "," ")"] @o.call.value.variant))

(call_expression function: (self_type) arguments: (arguments ["(" "," ")"] @o.call.type.self))

(call_expression function: (name) @_ (#semantic? @_ Struct) arguments: (arguments ["(" "," ")"] @o.call.type.struct))
(call_expression function: (scoped_name name: (name) @_ (#semantic? @_ Struct)) arguments: (arguments ["(" "," ")"] @o.call.type.struct))

(call_expression function: (name) @_ (#semantic? @_ "!trait" associated Function) arguments: (arguments ["(" "," ")"] @o.call.function.associated))
(call_expression function: (scoped_name name: (name) @_ (#semantic? @_ "!trait" associated Function)) arguments: (arguments ["(" "," ")"] @o.call.function.associated))
(call_expression function: (generic_function function: (name) @_ (#semantic? @_ "!trait" associated Function)) arguments: (arguments ["(" "," ")"] @o.call.function.associated))
(call_expression function: (generic_function function: (scoped_name name: (name) @_ (#semantic? @_ "!trait" associated Function))) arguments: (arguments ["(" "," ")"] @o.call.function.associated))

(call_expression function: (name) @_ (#semantic? @_ trait Function) arguments: (arguments ["(" "," ")"] @o.call.function.associated.extension))
(call_expression function: (scoped_name name: (name) @_ (#semantic? @_ trait Function)) arguments: (arguments ["(" "," ")"] @o.call.function.associated.extension))

(tuple_struct_pattern type: (name) @_ (#semantic? @_ EnumMember) ["(" "," ")"] @o.call.value.variant)
(tuple_struct_pattern type: (scoped_name name: (name) @_ (#semantic? @_ EnumMember)) ["(" "," ")"] @o.call.value.variant)

(tuple_struct_pattern type: (self_type) ["(" "," ")"] @o.call.type.self)

(tuple_struct_pattern type: (name) @_ (#semantic? @_ Struct) ["(" "," ")"] @o.call.type.struct)
(tuple_struct_pattern type: (scoped_name name: (name) @_ (#semantic? @_ Struct)) ["(" "," ")"] @o.call.type.struct)

(generic_function
    function: (name) @_ (#semantic? @_ EnumMember)
    "::" @o.call.value.variant
