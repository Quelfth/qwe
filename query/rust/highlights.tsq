(struct_pattern type: (scoped_type_name name: (type_name) @_ (#semantic? @_ EnumMember)) ["{" "," "}"] @o.call.value.variant)

; Type

(reference_type "&" @o.access.reference)
(pointer_type "*" @o.access.pointer)

(never_type "!" @o.type.never)
(self_type) @i.type.self
(unit_type ["(" ")"] @o.tuple)
(tuple_type ["(" "," ")"] @o.tuple)

(array_type ["[" ";" "]"] @o.construct.list)

(function_type "->" @o.declare.function)

((identifier) @i.type.builtin (#semantic? @i.type.builtin BuiltinType))
((identifier) @i.type.struct (#semantic? @i.type.struct Struct))
((identifier) @i.type.enum (#semantic? @i.type.enum Enum))
